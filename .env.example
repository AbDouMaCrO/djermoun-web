# Djermoun Auto — Environment Variables
# Copy this file to .env and fill in real values. Never commit .env.

# ── Supabase (marketing script + admin actions) ───────────────────────────────
# Use the same project URL as NEXT_PUBLIC_SUPABASE_URL in apps/web/.env.local
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key   # Settings > API > service_role

# ── Exchange rate fallback ────────────────────────────────────────────────────
# Only used if site_settings.usd_to_dzd_rate cannot be fetched from DB
DZD_RATE=253

# ── Contact ───────────────────────────────────────────────────────────────────
WHATSAPP_NUMBER=213xxxxxxxxx   # digits only, no +

# ── Marketing output ──────────────────────────────────────────────────────────
# MARKETING_OUTPUT_DIR=marketing-output   # default, override if needed
